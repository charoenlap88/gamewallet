# API base URL (ไม่มี slash ท้าย) — ต้องลงท้ายด้วย /api/v1 ให้ตรงกับ Nest globalPrefix
# Local dev ผ่าน Vite proxy: ปล่อยว่าง (ใช้ค่าใน client.ts)
# Production (โดเมนจริง):
# VITE_API_URL=https://www.playpaytopup.com/api/v1
VITE_API_URL=

# Google Sign-In — OAuth 2.0 Client ID (Web application). Same value as backend GOOGLE_CLIENT_ID.
# Leave empty to hide Google buttons in the UI.
VITE_GOOGLE_CLIENT_ID=

# Omise Public Key (สำหรับ Omise.js / แสดงฟอร์มชำระเงิน — ไม่ใส่ Secret ใน frontend)
VITE_OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxxxxxx
