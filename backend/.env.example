# App
NODE_ENV=development
PORT=3000
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=gamewallet
DB_PASSWORD=gamewallet123
DB_DATABASE=gamewallet_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Bcrypt
BCRYPT_ROUNDS=10

# Google Sign-In (OAuth 2.0 Client ID — Web application, same ID as frontend VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# Omise Payments (Thailand) — https://docs.omise.co/th/thailand
# ดู Public / Secret Key จาก Dashboard > API (ใช้ Test keys ตอนพัฒนา)
OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxxxxxx
OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxxxxxxxxxx
